# Copier ce fichier en ".env.dev" et renseigner les vraies valeurs (développement local)
# Le fichier ".env.dev" ne doit jamais être commité (voir .gitignore)
# Chargé automatiquement par BackendRekoltHt/settings/dev.py

# Clé secrète Django (une valeur de secours non sécurisée est utilisée si absente en dev)
SECRET_KEY=change-moi-en-local

# Identifiants OAuth2 Google
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Configuration email SMTP (envoi des codes de réinitialisation de mot de passe, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Chemin vers le python d'un second environnement dédié à DeepFace (voir
# requirements-face.txt et Registration/services/face_service.py) — incompatible
# en environnement partagé avec paddleocr/paddlepaddle (conflit protobuf).
# Ex Windows : C:\chemin\vers\venv_face\Scripts\python.exe
# Ex Linux/macOS : /chemin/vers/venv_face/bin/python
# Laisser vide désactive la vérification faciale automatique (revue manuelle
# systématique, voir _lancer_verification_faciale, Registration/views.py)
FACE_VENV_PYTHON=
