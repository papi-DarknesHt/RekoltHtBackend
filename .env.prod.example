# Sur Render, NE PAS créer ce fichier : renseigner ces mêmes variables dans le
# tableau de bord Render (Environment). Ce modèle sert surtout à tester la
# config prod en local (copier en ".env.prod" — jamais commité, voir .gitignore).
# Chargé automatiquement par BackendRekoltHt/settings/prod.py

# Clé secrète Django — OBLIGATOIRE, valeur forte et unique, différente de celle du dev
SECRET_KEY=

# Identifiants OAuth2 Google
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=

# Configuration email SMTP (envoi des codes de réinitialisation de mot de passe, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Domaines autorisés, séparés par une virgule et sans espaces
ALLOWED_HOSTS=rekolthtbackend.onrender.com

# Base de données PostgreSQL (fournie par Render : onglet "Info" de la base)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Stockage média externe Cloudinary — voir settings/prod.py (MEDIA_ROOT ne
# fonctionne pas sur Render : filesystem éphémère, tout est perdu au redéploiement).
# Format : cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# Chemin vers le python d'un second environnement (build/service séparé sur le
# serveur) dédié à DeepFace — voir requirements-face.txt et
# Registration/services/face_service.py. Incompatible en environnement partagé
# avec paddleocr/paddlepaddle (conflit protobuf, voir requirements.txt).
# Laisser vide désactive la vérification faciale automatique (revue manuelle
# systématique, voir _lancer_verification_faciale, Registration/views.py).
FACE_VENV_PYTHON=
